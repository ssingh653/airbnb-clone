# Use an explicit, lightweight official Node.js Alpine base image
FROM node:22-alpine

# Set the active working directory inside the container
WORKDIR /usr/src/app

# Copy dependency manifests first to leverage Docker layer caching
COPY package*.json ./

# Install
RUN npm install

# Copy the remaining application source files
COPY . .

# Document the port your application listens on
EXPOSE 3000

# Define the default execution command
CMD ["node", "index.js"]